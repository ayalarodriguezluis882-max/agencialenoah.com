<script>
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){ e.target.classList.add('show'); io.unobserve(e.target); }
    });
  }, {threshold:0.15});
  revealEls.forEach(el=>io.observe(el));

  /* ==========================================================
     Fondo cinemático: cruce fronterizo de noche con estelas
     de luz (estilo fotografía de larga exposición), reflejo
     en el pavimento y siluetas de casetas/postes de garita.
  ========================================================== */
  (function(){
    const canvas = document.getElementById('garita-canvas');
    const ctx = canvas.getContext('2d');
    const hero = canvas.closest('.hero');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let W, H, DPR, groundY;
    let streaks = [];
    let bokeh = [];

    function resize(){
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      W = hero.offsetWidth;
      H = hero.offsetHeight;
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(DPR,0,0,DPR,0,0);
      groundY = H * 0.64;
      ctx.fillStyle = '#150D05';
      ctx.fillRect(0,0,W,H);
      buildScene();
    }

    const LANES = [];
    function buildScene(){
      // carriles de cruce (varios van a EE. UU., otros a México)
      LANES.length = 0;
      const top = H*0.30, bottom = groundY - 10;
      const n = 5;
      for(let i=0;i<n;i++){
        LANES.push({
          y: top + ((bottom-top)/(n-1))*i,
          dir: i % 2 === 0 ? 1 : -1 // alterna dirección
        });
      }

      // luces distantes (bokeh)
      bokeh = [];
      const bn = 22;
      for(let i=0;i<bn;i++){
        bokeh.push({
          x: Math.random()*W,
          y: Math.random()*(H*0.42),
          r: 1.4 + Math.random()*2.6,
          baseA: 0.15 + Math.random()*0.35,
          phase: Math.random()*Math.PI*2,
          speed: 0.15 + Math.random()*0.2,
          hue: Math.random() > 0.5 ? '247,195,49' : '252,247,236'
        });
      }

      streaks = [];
    }

    function spawnStreak(lane){
      const fromLeft = lane.dir === 1;
      streaks.push({
        lane,
        x: fromLeft ? -60 - Math.random()*160 : W + 60 + Math.random()*160,
        len: 70 + Math.random()*90,
        speed: (1.1 + Math.random()*1.3) * lane.dir,
        color: fromLeft ? '252,247,236' : '229,120,60', // saliendo: cálido claro / entrando: ámbar-rojizo
        alpha: 0.55 + Math.random()*0.35
      });
    }

    function drawStaticStructures(){
      // caseta / canopy central de inspección
      const cw = W*0.20, cx = W*0.5 - cw/2, roofY = groundY - 92, roofH = 10;
      ctx.fillStyle = 'rgba(10,7,3,0.92)';
      ctx.fillRect(cx, roofY, cw, roofH);
      ctx.fillRect(cx+8, roofY+roofH, 7, 82);
      ctx.fillRect(cx+cw-15, roofY+roofH, 7, 82);

      // postes de iluminación a los lados
      const masts = [W*0.08, W*0.22, W*0.78, W*0.92];
      masts.forEach((mx,i)=>{
        const mh = 70 + (i%2===0 ? 18 : 0);
        ctx.fillStyle = 'rgba(10,7,3,0.92)';
        ctx.fillRect(mx-1.5, groundY-mh, 3, mh);
        ctx.fillRect(mx-11, groundY-mh-5, 22, 5);
        // resplandor cálido de la lámpara
        const g = ctx.createRadialGradient(mx, groundY-mh-3, 0, mx, groundY-mh-3, 26);
        g.addColorStop(0, 'rgba(247,195,49,0.55)');
        g.addColorStop(1, 'rgba(247,195,49,0)');
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.arc(mx, groundY-mh-3, 26, 0, Math.PI*2);
        ctx.fill();
      });
    }

    function frame(now){
      // capa de desvanecimiento (crea el efecto de estela de larga exposición)
      ctx.globalCompositeOperation = 'source-over';
      ctx.fillStyle = 'rgba(21,13,5,0.16)';
      ctx.fillRect(0,0,W,H);

      // suelo / piso mojado con degradado
      const groundGrad = ctx.createLinearGradient(0, groundY, 0, H);
      groundGrad.addColorStop(0, 'rgba(10,7,3,1)');
      groundGrad.addColorStop(1, 'rgba(5,3,1,1)');
      ctx.fillStyle = groundGrad;
      ctx.fillRect(0, groundY, W, H-groundY);

      drawStaticStructures();

      // luces distantes parpadeando
      bokeh.forEach(b=>{
        const a = b.baseA + Math.sin(now*0.001*b.speed + b.phase) * 0.12;
        const g = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r*4);
        g.addColorStop(0, `rgba(${b.hue},${Math.max(a,0)})`);
        g.addColorStop(1, `rgba(${b.hue},0)`);
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r*4, 0, Math.PI*2);
        ctx.fill();
      });

      if(reduceMotion){
        // marco estático: un par de estelas fijas por carril, sin animación
        LANES.forEach(lane=>{
          ctx.strokeStyle = `rgba(${lane.dir===1 ? '252,247,236' : '229,120,60'},0.5)`;
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(W*0.15, lane.y);
          ctx.lineTo(W*0.45, lane.y);
          ctx.stroke();
        });
        return;
      }

      // estelas de luz (aditivo, efecto de brillo real)
      ctx.globalCompositeOperation = 'lighter';
      streaks.forEach(s=>{
        s.x += s.speed;
        const tailX = s.x - s.len*Math.sign(s.speed||1);
        const grad = ctx.createLinearGradient(s.x, s.lane.y, tailX, s.lane.y);
        grad.addColorStop(0, `rgba(${s.color},${s.alpha})`);
        grad.addColorStop(1, `rgba(${s.color},0)`);
        ctx.strokeStyle = grad;
        ctx.lineWidth = 2.2;
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(s.x, s.lane.y);
        ctx.lineTo(tailX, s.lane.y);
        ctx.stroke();

        // cabeza brillante (faro)
        const headG = ctx.createRadialGradient(s.x, s.lane.y, 0, s.x, s.lane.y, 5);
        headG.addColorStop(0, `rgba(${s.color},${Math.min(s.alpha+0.2,1)})`);
        headG.addColorStop(1, `rgba(${s.color},0)`);
        ctx.fillStyle = headG;
        ctx.beginPath();
        ctx.arc(s.x, s.lane.y, 5, 0, Math.PI*2);
        ctx.fill();

        // reflejo tenue en el piso mojado
        const ry = groundY + (groundY - s.lane.y)*0.22;
        if(ry < H){
          const rGrad = ctx.createLinearGradient(s.x, ry, tailX, ry);
          rGrad.addColorStop(0, `rgba(${s.color},${s.alpha*0.28})`);
          rGrad.addColorStop(1, `rgba(${s.color},0)`);
          ctx.strokeStyle = rGrad;
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(s.x, ry);
          ctx.lineTo(tailX, ry);
          ctx.stroke();
        }
      });
      ctx.globalCompositeOperation = 'source-over';

      streaks = streaks.filter(s => s.x > -260 && s.x < W+260);
      if(Math.random() < 0.045){
        const lane = LANES[Math.floor(Math.random()*LANES.length)];
        spawnStreak(lane);
      }

      requestAnimationFrame(frame);
    }

    resize();
    window.addEventListener('resize', resize);

    if(reduceMotion){ frame(performance.now()); }
    else { requestAnimationFrame(frame); }
  })();
</script>

